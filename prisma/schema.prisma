generator client {
  provider      = "prisma-client-js"
  // native = 開発OS(Windows), debian-openssl-3.0.x = WSL/Linux 実行用
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Event {
  id          String   @id @default(cuid())
  workspaceId String   @default("default")
  title       String
  description String?
  start       DateTime
  end         DateTime
  allDay      Boolean  @default(false)
  color       String   @default("#3b82f6")
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
}

model Task {
  id             String    @id @default(cuid())
  workspaceId    String    @default("default")
  title          String
  description    String?
  startDate      DateTime?
  deadline       DateTime
  priority       String    @default("medium")
  status         String    @default("pending")
  estimatedHours Float?
  color          String    @default("#8b5cf6")
  templateId     String?
  subtasks       SubTask[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([workspaceId])
}

model SubTask {
  id             String    @id @default(cuid())
  taskId         String
  task           Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title          String
  estimatedHours Float?
  order          Int       @default(0)
  status         String    @default("pending")
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model UserSettings {
  id            String   @id @default(cuid())
  workspaceId   String   @unique @default("default")
  workStartHour Int      @default(9)
  workEndHour   Int      @default(21)
  timezone      String   @default("Asia/Tokyo")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TaskTemplate {
  id              String   @id @default(cuid())
  workspaceId     String   @default("default")
  title           String
  description     String?
  estimatedHours  Float?
  defaultSubtasks String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([workspaceId])
}

// ===== Auth.js (NextAuth v5) — Google/Discord ログイン用 =====
// ログイン中ユーザーのワークスペースIDは "u_<User.id>" として扱う（lib/workspace.ts）。

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}
